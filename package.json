{
  "name": "nimblco",
  "version": "0.2.2",
  "description": "Portable agentic coding workflow layer. Embed into any repo to give AI coding agents structured task briefs, specs, plans, and handoff packs.",
  "license": "MIT",
  "keywords": [
    "ai",
    "agents",
    "workflow",
    "agentic",
    "scaffold",
    "copilot",
    "claude",
    "gemini",
    "codex",
    "task-brief"
  ],
  "bin": {
    "nimblco": "./scripts/init-workflow.mjs"
  },
  "files": [
    "scripts/",
    "docs/",
    "!docs/**/archive/",
    "skills/",
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    ".editorconfig",
    ".agent/",
    ".aider.conf.yml",
    ".claude/",
    ".claude-plugin/",
    ".continue/",
    ".cursor/",
    ".github/",
    ".vscode/extensions.json",
    ".windsurfrules",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "pnpm -r --if-present lint",
    "test": "node --test",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "check": "powershell -ExecutionPolicy Bypass -File .\\scripts\\check.ps1",
    "workflow": "node ./scripts/workflow.mjs",
    "init-workflow": "node ./scripts/init-workflow.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nimblco/nimblco.git"
  },
  "engines": {
    "node": ">=18"
  }
}
